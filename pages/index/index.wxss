/* pages/index/index.wxss */
page {
  background-color: #f4f5f9;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei',
    sans-serif;
}

.container {
  padding: 30rpx;
}

/* 图表面板样式 */
.chart-panel {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 40rpx;
}

.panel-title {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-align: center;
}

.mood-canvas {
  width: 100%;
  height: 200px;
}

/* 表单面板样式 */
.form-box {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.display-index {
  text-align: center;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1px dashed #eee;
}

.highlight {
  color: #07c160;
  font-size: 40rpx;
  font-weight: bold;
}

.input-group {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.input-field, .picker-box {
  background: #f8f9fa;
  border: 1px solid #e2e2e2;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
}

/* 按钮样式 */
.btn-submit {
  background-color: #07c160;
  color: white;
  border-radius: 50rpx;
  font-size: 32rpx;
  margin-top: 50rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 16rpx rgba(7, 193, 96, 0.3);
}

.btn-undo {
  background-color: #fff;
  color: #ff4d4f;
  border: 1px solid #ff4d4f;
  border-radius: 50rpx;
  font-size: 28rpx;
  margin-top: 20rpx;
}